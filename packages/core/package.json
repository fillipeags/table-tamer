{
  "name": "@table-tamer/core",
  "version": "0.3.1",
  "private": false,
  "description": "Protocol types and utilities for Table Tamer",
  "author": "fillipeags",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fillipeags/table-tamer.git",
    "directory": "packages/core"
  },
  "keywords": [
    "watermelondb",
    "sqlite",
    "inspector",
    "react-native",
    "database"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
